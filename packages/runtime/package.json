{
  "name": "@threadline/runtime",
  "version": "1.0.0",
  "description": "Threadline runtime for object-form handoffs with safe fallbacks.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "SPEC.md",
    "CONTEXT.md"
  ],
  "scripts": {
    "build": "node --disable-warning=ExperimentalWarning ./scripts/build.mjs",
    "test": "node --test test/**/*.test.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "threadline",
    "runtime",
    "handoff"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Cynamide/threadline",
    "directory": "packages/runtime"
  },
  "author": "Cynamide",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
