{
  "name": "ui-copilot",
  "version": "1.0.0",
  "private": true,
  "description": "AI-Powered Design-to-React Implementation & Handoff Tool",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "turbo": "^1.12.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ui-copilot",
    "react",
    "ai",
    "design",
    "handoff",
    "cursor",
    "copilot"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/ui-copilot"
  },
  "author": "Your Organization",
  "license": "MIT"
}
