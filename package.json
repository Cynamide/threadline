{
  "name": "threadline",
  "version": "1.0.0",
  "private": true,
  "description": "Threadline is a local monorepo for design-to-React implementation with guardrails.",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "turbo run lint",
    "pack:local": "pnpm --filter @threadline/cli pack:local",
    "pack:packages": "mkdir -p /tmp/threadline-package-packs && pnpm -r --filter './packages/*' pack --pack-destination /tmp/threadline-package-packs",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "turbo": "^1.12.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=22.13.0"
  },
  "keywords": [
    "threadline",
    "react",
    "ai",
    "design",
    "handoff",
    "cursor"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Cynamide/threadline"
  },
  "author": "Cynamide",
  "license": "MIT"
}
